generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = "mysql://root:password@localhost:3306/star_crm_db"
}

// --- TABLAS CORE ---

model User {
  id           String   @id @db.Char(36) // UUID de Supabase Auth
  email        String   @unique
  full_name    String?
  role         String   @default("user") // 'admin', 'agent'
  avatar_url   String?  @db.Text
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  // Relaciones
  assigned_clients Client[]      @relation("AssignedAgent")
  created_clients  Client[]      @relation("ClientCreator")
  assigned_deals   Deal[]        @relation("DealAgent")
  quotes           Quote[]       @relation("QuoteCreator")
  appointments     Appointment[]
  notifications    Notification[]

  @@map("users")
}

model Client {
  id                String   @id @default(uuid())
  company_name      String
  contact_name      String?
  email             String?
  phone             String?
  tax_id            String?  // RUC / Cédula Jurídica
  address           String?  @db.Text
  assigned_agent_id String?  @db.Char(36)
  created_by        String   @db.Char(36)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  // Relaciones
  agent   User?   @relation("AssignedAgent", fields: [assigned_agent_id], references: [id])
  creator User    @relation("ClientCreator", fields: [created_by], references: [id])
  deals   Deal[]
  quotes  Quote[]
  appointments Appointment[]

  @@map("clients")
}

model Deal {
  id                Int      @id @default(autoincrement())
  title             String
  description       String?  @db.Text
  value             Decimal  @default(0) @db.Decimal(15, 2)
  currency          String   @default("USD") @db.Char(3)
  status            String   // 'LEAD', 'CONTACTADO', 'NEGOCIACION', etc.
  client_id         String
  assigned_agent_id String?  @db.Char(36)
  priority          String   @default("MEDIUM") // 'LOW', 'MEDIUM', 'HIGH'
  expected_close_date DateTime?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  client Client @relation(fields: [client_id], references: [id])
  agent  User?  @relation("DealAgent", fields: [assigned_agent_id], references: [id])

  @@index([status])
  @@index([assigned_agent_id])
  @@map("deals")
}

model Quote {
  id             String   @id @default(uuid())
  quote_number   String   @unique // Ej: Q-2026-001
  client_id      String
  created_by     String   @db.Char(36)
  status         String   @default("DRAFT") // 'DRAFT', 'SENT', 'APPROVED', 'REJECTED'
  total_amount   Decimal  @db.Decimal(15, 2)
  currency       String   @default("USD")
  exchange_rate  Decimal  @default(1) @db.Decimal(10, 4)
  valid_until    DateTime?
  pdf_url        String?  @db.Text
  notes          String?  @db.Text
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  client  Client       @relation(fields: [client_id], references: [id])
  creator User         @relation("QuoteCreator", fields: [created_by], references: [id])
  items   QuoteItem[]

  @@map("quotes")
}

model QuoteItem {
  id          Int     @id @default(autoincrement())
  quote_id    String
  description String
  quantity    Int     @default(1)
  unit_price  Decimal @db.Decimal(15, 2)
  total       Decimal @db.Decimal(15, 2)
  
  quote Quote @relation(fields: [quote_id], references: [id], onDelete: Cascade)

  @@map("quote_items")
}

model Appointment {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  start_date  DateTime
  end_date    DateTime
  client_id   String?
  user_id     String   @db.Char(36)
  meeting_url String?  @db.Text
  location    String?
  status      String   @default("SCHEDULED") // 'SCHEDULED', 'COMPLETED', 'CANCELLED'
  created_at  DateTime @default(now())

  client Client? @relation(fields: [client_id], references: [id])
  user   User    @relation(fields: [user_id], references: [id])

  @@map("appointments")
}

model Notification {
  id          Int      @id @default(autoincrement())
  user_id     String   @db.Char(36)
  title       String
  message     String   @db.Text
  type        String   // 'INFO', 'WARNING', 'SUCCESS'
  read        Boolean  @default(false)
  link        String?
  created_at  DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id, read])
  @@map("notifications")
}
